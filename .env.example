# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Pinterest API Credentials
PINTEREST_CLIENT_ID="YOUR_PINTEREST_CLIENT_ID"
PINTEREST_CLIENT_SECRET="YOUR_PINTEREST_CLIENT_SECRET"
# Optional: Hardcode the redirect URI if needed. If not set, it will be constructed from APP_URL or request host.
# PINTEREST_REDIRECT_URI="https://your-app.run.app/auth/pinterest/callback"

# App URL (Required for reliable OAuth redirect URI construction)
APP_URL="https://ais-dev-nsdsoziw67mxs7smy6g43b-144320193433.us-west1.run.app"

# Vercel Deployment (Optional)
# VERCEL="true"
# CRON_SECRET="your_random_secret_here"
# FIREBASE_SERVICE_ACCOUNT='{"project_id": "...", "private_key": "...", "client_email": "..."}'
